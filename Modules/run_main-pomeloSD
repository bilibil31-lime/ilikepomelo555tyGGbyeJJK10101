local floatDragging, floatDragStart, floatStartPos
local floatHasMoved = false 

FloatingBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        floatDragging = true
        floatHasMoved = false
        floatDragStart = input.Position
        floatStartPos = UDim2.new(0, FloatingBtn.AbsolutePosition.X, 0, FloatingBtn.AbsolutePosition.Y)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if floatDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - floatDragStart
        if delta.Magnitude > 3 then floatHasMoved = true end
        local viewport = Camera.ViewportSize
        local floatSize = FloatingBtn.AbsoluteSize
        local newX = math.clamp(floatStartPos.X.Offset + delta.X, 0, viewport.X - floatSize.X)
        local newY = math.clamp(floatStartPos.Y.Offset + delta.Y, 0, viewport.Y - floatSize.Y)
        FloatingBtn.Position = UDim2.new(0, newX, 0, newY)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
        floatDragging = false 
    end
end)

