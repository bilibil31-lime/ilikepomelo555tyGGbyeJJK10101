local TabsData = {}

local function CreateTab(tabName, scriptContent)
    local TabBtn = Instance.new("TextButton")
    TabBtn.Parent = TabBar
    TabBtn.Size = UDim2.new(0, 100, 0, 24) 
    TabBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 52)
    TabBtn.BackgroundTransparency = 0.2
    TabBtn.Text = tabName
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabBtn.Font = Enum.Font.Jura
    TabBtn.TextSize = 13
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)
    
    local Stroke, Gradient = ApplyGradientGlow(TabBtn, 1)
    Stroke.Transparency = 1 
    
    local PageFrame = Instance.new("Frame")
    PageFrame.Parent = ContentContainer
    PageFrame.Size = UDim2.new(1, 0, 1, 0)
    PageFrame.BackgroundTransparency = 1
    PageFrame.Visible = false
    
    local tabInfo = {Btn = TabBtn, Page = PageFrame, Loaded = false, Stroke = Stroke}
    table.insert(TabsData, tabInfo)
    
    TabBtn.MouseButton1Click:Connect(function()
        PlayClick()
        for _, t in ipairs(TabsData) do
            t.Page.Visible = false
            t.Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
            TweenService:Create(t.Stroke, TweenInfo.new(0.2), {Transparency = 1}):Play()
            TweenService:Create(t.Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 45, 52)}):Play()
        end
        PageFrame.Visible = true
        TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        TweenService:Create(Stroke, TweenInfo.new(0.2), {Transparency = 0}):Play()
        TweenService:Create(TabBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 60, 70)}):Play()
        
        if not tabInfo.Loaded and scriptContent and scriptContent ~= "" then
            tabInfo.Loaded = true
            task.spawn(function()
                _G.CurrentPomeloTab = PageFrame 
                local func, err = loadstring(scriptContent)
                if func then pcall(func) else warn("Error loading tab: " .. tabName .. " | Error: " .. tostring(err)) end
            end)
        end
    end)
    
    if #TabsData == 1 then
        TabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        Stroke.Transparency = 0
        TabBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        PageFrame.Visible = true
        if not tabInfo.Loaded and scriptContent and scriptContent ~= "" then
            tabInfo.Loaded = true
            task.spawn(function()
                _G.CurrentPomeloTab = PageFrame
                local func = loadstring(scriptContent)
                if func then pcall(func) end
            end)
        end
    end
end

task.spawn(function()
    local success, rawData = pcall(function() return game:HttpGet(LINK_TABS_DATA) end)
    if success and rawData and rawData ~= "" then
        local inScript = false
        local currentName = nil
        local currentScriptCode = {}
        for line in rawData:gmatch("([^\r\n]+)") do
            if not inScript then
                local tabNameMatch = string.match(line, "TAB%d+%s*name=(.+)")
                if tabNameMatch then
                    currentName = string.match(tabNameMatch, "^%s*(.-)%s*$")
                elseif currentName and string.match(line, "%[%.%.%.") then
                    inScript = true
                    currentScriptCode = {} 
                end
            else
                if string.match(line, "%]%.%.%.") then
                    inScript = false
                    if currentName then
                        CreateTab(currentName, table.concat(currentScriptCode, "\n"))
                        currentName = nil
                    end
                else
                    table.insert(currentScriptCode, line)
                end
            end
        end
    end
end)

