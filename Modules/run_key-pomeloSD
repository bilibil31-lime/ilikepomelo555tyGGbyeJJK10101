local function EncodeData(key, kType, expireTime, credits)
    local rawData = string.format("K:%s|T:%s|E:%d|C:%d|SALT:%s", key, kType, expireTime, credits, tostring(math.random(10000, 99999)))
    local hexData = (rawData:gsub(".", function(c) return string.format("%02X", string.byte(c)) end))
    return "POMELO_SECURE_V1\n" .. hexData .. "\nEOF"
end

local function DecodeData(dataStr)
    local hexData = string.match(dataStr, "POMELO_SECURE_V1\n([%a%d]+)\nEOF")
    if not hexData then return nil end
    local rawData = (hexData:gsub("%x%x", function(c) return string.char(tonumber(c, 16)) end))
    local k, t, e, c = string.match(rawData, "K:([^|]+)|T:([^|]+)|E:(%d+)|C:(%d+)")
    if k and t and e and c then return {key = k, type = t, expire = tonumber(e), credits = tonumber(c)} end
    return nil
end

local function SaveKeyData(key, kType, durationSecs, credits)
    if makefolder and not isfolder(FOLDER_NAME) then makefolder(FOLDER_NAME) end
    if writefile then
        local expireTime = os.time() + durationSecs
        writefile(FILE_NAME, EncodeData(key, kType, expireTime, credits))
    end
end

local function GetLocalKeyData()
    if isfolder and isfolder(FOLDER_NAME) and isfile and isfile(FILE_NAME) then
        return DecodeData(readfile(FILE_NAME))
    end
    return nil
end

